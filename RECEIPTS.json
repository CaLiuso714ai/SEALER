    },
    "anti_drift": [
      "no mutations allowed — only append to receipts array",
      "issued_at must be strictly after source_event timestamp",
      "R-SEAL-DECISION may only be appended after all other required_receipt_types are present and PASS"
    ],
    "seal_admissibility_gate": "R-SEAL-DECISION.status=PASS only if every required_receipt_type has status=PASS and fresh_context confirmed in MEMORY.json",
